# Registry configuration for @symphony-ai scope
# Uncomment and configure one of the following based on your registry:

# --- Option A: npm public registry (recommended for public packages) ---
# @symphony-ai:registry=https://registry.npmjs.org/
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# --- Option B: GitHub Packages ---
# @symphony-ai:registry=https://npm.pkg.github.com/
# //npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}

# --- Option C: Azure Artifacts ---
# @symphony-ai:registry=https://pkgs.dev.azure.com/<org>/_packaging/<feed>/npm/registry/
# //pkgs.dev.azure.com/<org>/_packaging/<feed>/npm/registry/:_authToken=${AZURE_TOKEN}

# General settings
always-auth=true
auto-install-peers=true
